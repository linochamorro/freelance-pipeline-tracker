generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PipelineStage {
  Lead
  Contacted
  InDiscussion
  ProposalSent
  Negotiation
  Accepted
  Rejected
  OnHold
  InDevelopment
  Completed
}

enum PaymentStatus {
  Quoted
  Pending
  Collected
}

enum DevelopmentStatus {
  Pending
  InProgress
  OnPause
  Completed
}

enum ContactChannel {
  LinkedIn
  Email
  Referral
  ColdOutreach
  WhatsApp
  Other
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  accounts       Account[]
  sessions       Session[]
  opportunities  Opportunity[]
  userSettings   UserSettings?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Opportunity {
  id                String            @id @default(cuid())
  userId            String
  clientName        String
  description       String
  estimatedBudget   Float
  contactPersonName String
  contactChannel    ContactChannel
  pipelineStage     PipelineStage     @default(Lead)
  paymentStatus     PaymentStatus?
  developmentStatus DevelopmentStatus?
  isArchived        Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes             Note[]
  stageChanges      StageChange[]

  @@index([userId])
  @@index([userId, pipelineStage])
  @@index([userId, isArchived])
}

model Note {
  id             String      @id @default(cuid())
  opportunityId  String
  content        String
  createdAt      DateTime    @default(now())
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
}

model StageChange {
  id             String         @id @default(cuid())
  opportunityId  String
  fromStage      PipelineStage
  toStage        PipelineStage
  createdAt      DateTime       @default(now())
  opportunity    Opportunity    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
}

model UserSettings {
  id                      String          @id @default(cuid())
  userId                  String          @unique
  leadStalenessDays       Int             @default(7)
  contactedStalenessDays  Int             @default(7)
  discussionStalenessDays Int             @default(7)
  proposalStalenessDays   Int             @default(7)
  negotiationStalenessDays Int            @default(7)
  acceptedStalenessDays   Int             @default(7)
  onHoldStalenessDays     Int             @default(7)
  developmentStalenessDays Int            @default(7)
  notificationEnabled     Boolean         @default(true)
  user                    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}
